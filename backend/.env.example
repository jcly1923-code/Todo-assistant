# Copy to .env and fill in values. Never commit .env.

# --- Recommended for production ---
# APP_ENV=production
# JWT_SECRET=replace-with-long-random-string
# ADMIN_JWT_SECRET=replace-with-different-long-random-string
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=use-a-strong-unique-password
# PUBLIC_APP_URL=https://your-domain.example

# --- Database (default: SQLite under backend/data/) ---
# DATABASE_URL=sqlite+aiosqlite:///./data/todo.db

# --- AI (optional fallbacks; users can also set keys in the app UI) ---
# LITELLM_MODEL=openai/gpt-3.5-turbo
# LITELLM_API_KEY=
# LITELLM_BASE_URL=

# --- Migration / legacy bootstrap (only if needed) ---
# BOOTSTRAP_USER_EMAIL=
# BOOTSTRAP_USER_PASSWORD=
